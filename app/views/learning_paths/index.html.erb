<div class="container learning-paths-page pb-5">
  <div class="row align-items-center mb-4">
    <div class="col-md-8">
      <h1 class="display-5 fw-bold text-dark">
        <i class="bi bi-signpost-2 me-2 text-primary"></i>
        <%= t('learning_paths.index.title') %>
      </h1>
      <p class="text-muted fs-5"><%= t('learning_paths.index.subtitle') %></p>
    </div>
    <div class="col-md-4">
      <%= form_with url: learning_paths_path, method: :get, local: true, class: "d-flex" do |f| %>
        <%= f.text_field :search, value: params[:search], class: "form-control me-2 search-input", placeholder: t('learning_paths.index.search_placeholder') %>
        <%= f.submit t('learning_paths.index.search_button'), class: "btn btn-primary", name: nil %>
      <% end %>
    </div>
  </div>

  <% if @learning_paths.present? %>
    <div class="row g-4">
      <% @learning_paths.each do |path| %>
        <%= render "learning_path_form", path: path %>
      <% end %>
    </div>
  <% else %>
    <%= render "empty_page_template" %>
  <% end %>
</div>
