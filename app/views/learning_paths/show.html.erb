<div class="container learning-paths-page pb-5">
  <div class="row">
    <div class="col-lg-8 mx-auto">
      <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><%= link_to t('learning_paths.show.breadcrumb_all'), learning_paths_path %></li>
          <li class="breadcrumb-item active" aria-current="page"><%= @learning_path.title %></li>
        </ol>
      </nav>

      <div class="card learning-path-detail-card border-0 shadow-sm rounded-4 p-4 mb-5">
        <h1 class="display-6 fw-bold text-dark"><%= @learning_path.title %></h1>
        <p class="text-muted fs-5 mt-3"><%= @learning_path.description %></p>
        <hr class="my-4">
        <div class="d-flex gap-3">
          <%= link_to t('learning_paths.show.back_to_list'), learning_paths_path, class: "btn btn-outline-secondary rounded-pill px-4" %>
          <% if policy(@learning_path).update? %>
            <%= link_to t('learning_paths.show.edit_curriculum'), edit_learning_path_path(@learning_path), class: 'btn btn-outline-warning' %>
          <% end %>
        </div>
      </div>

      <div class="course-content-section">
        <h3 class="fw-bold mb-4"><%= t('learning_paths.show.curriculum') %></h3>

        <% if @learning_path.course_contents.any? %>
          <%= render "course_section" %>
        <% else %>
          <div class="alert alert-secondary border-0 shadow-sm rounded-4 text-center p-4">
            <%= t('learning_paths.show.no_lessons') %>
          </div>
        <% end %>
      </div>

    </div>
  </div>
</div>
