<div class="content-block bg-white p-4 rounded-3 shadow-sm mb-3">
  <% case element %>
  <% when Elements::Markdown %>
    <div class="markdown-body text-dark">
      <%= simple_format(element.body) %>
    </div>
    
  <% when Elements::Video %>
    <div class="video-body d-flex align-items-center gap-3">
      <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-circle">
        <i class="bi bi-play-circle-fill fs-4"></i>
      </div>
      <div>
        <h6 class="mb-1 fw-bold"><%= t('learning_paths.show.video_material') %></h6>
        <%= link_to t('common.watch_video'), element.url, class: "text-decoration-none", target: "_blank", rel: "noopener noreferrer" %>
      </div>
    </div>
    
  <% when Elements::Code %>
    <div class="code-body">
      <% if element.language.present? %>
        <span class="badge bg-secondary mb-2 px-3 py-2"><%= element.language.upcase %></span>
      <% end %>
      <pre class="bg-dark text-light p-3 rounded-3 mb-0"><code><%= element.content %></code></pre>
    </div>

  <% when Elements::Asset %>
    <div class="asset-body d-flex align-items-center gap-3">
      <div class="bg-secondary bg-opacity-10 text-secondary p-3 rounded-circle">
        <i class="bi bi-paperclip fs-4"></i>
      </div>
      <div>
        <h6 class="mb-1 fw-bold"><%= t('learning_paths.show.asset_material') %></h6>
        <%= link_to element.url, element.url, class: "text-decoration-none", target: "_blank", rel: "noopener noreferrer" %>
      </div>
    </div>
  <% end %>
</div>
