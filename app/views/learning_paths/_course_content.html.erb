<div class="content-block bg-white p-4 rounded-3 shadow-sm mb-3">
  <% case element["type"] %>
  <% when "markdown" %>
    <div class="markdown-body">
      <%= simple_format(element["body"]) %>
    </div>
    
  <% when "video" %>
    <div class="video-body d-flex align-items-center gap-3">
      <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-circle">
        <i class="bi bi-play-circle-fill fs-4"></i>
      </div>
      <div>
        <h6 class="mb-1 fw-bold"><%= t('learning_paths.show.video_material') %></h6>
        <%= link_to "Смотреть видео", element["url"], class: "text-decoration-none", target: "_blank", rel: "noopener noreferrer" %>
      </div>
    </div>
    
  <% when "code_block" %>
    <div class="code-body">
      <span class="badge bg-secondary mb-2 px-3 py-2"><%= element["language"].upcase %></span>
      <pre class="bg-dark text-light p-3 rounded-3 mb-0"><code><%= element["code"] %></code></pre>
    </div>
  <% end %>
</div>
