<div class="text-center mt-4">
  <%- if controller_name != 'sessions' %>
    <%= link_to t('devise.shared.links.sign_in', default: 'Log in'), new_session_path(resource_name), class: 'btn btn-outline-primary btn-sm me-2' %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to t('devise.shared.links.sign_up', default: 'Sign up'), new_registration_path(resource_name), class: 'btn btn-outline-primary btn-sm me-2' %>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to t('devise.shared.links.forgot_password', default: 'Forgot your password?'), new_password_path(resource_name), class: 'btn btn-link btn-sm' %>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <br><%= link_to t('devise.shared.links.didn_t_receive_confirmation', default: "Didn't receive confirmation instructions?"), new_confirmation_path(resource_name), class: 'btn btn-link btn-sm' %>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <br><%= link_to t('devise.shared.links.didn_t_receive_unlock', default: "Didn't receive unlock instructions?"), new_unlock_path(resource_name), class: 'btn btn-link btn-sm' %>
  <% end %>

  <%- if devise_mapping.omniauthable? %>
    <%- resource_class.omniauth_providers.each do |provider| %>
      <br><%= button_to "Sign in with #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: 'btn btn-outline-secondary btn-sm' %>
    <% end %>
  <% end %>
</div>
