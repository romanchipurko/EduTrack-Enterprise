<section class="hero">
  <div class="container">
    <p class="hero-label"><i class="bi bi-stars me-2"></i><%= t('home.hero.label') %></p>
    <h1 class="hero-title"><%= t('home.hero.title') %></h1>
    <p class="hero-subtitle"><%= t('home.hero.subtitle') %></p>
    <div class="hero-buttons">
      <%= link_to "#architecture", class: "btn btn-primary btn-lg px-4 py-3 fw-semibold" do %>
        <i class="bi bi-compass me-2"></i> <%= t('home.hero.explore') %>
      <% end %>
      <%= link_to "https://github.com", target: "_blank", class: "btn btn-outline-light btn-lg px-4 py-3 fw-semibold" do %>
        <i class="bi bi-github me-2"></i> <%= t('home.hero.github') %>
      <% end %>
    </div>
  </div>
</section>
