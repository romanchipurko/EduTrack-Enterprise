<section id="architecture" class="architecture">
  <div class="container">
    <h2><i class="bi bi-diagram-3 me-2 text-primary"></i><%= t('home.architecture.title') %></h2>
    <div class="architecture-flow">
      <div class="flow-item">
        <i class="bi bi-signpost-2 fs-1 d-block mb-2 text-primary"></i>
        <%= t('home.architecture.items.learning_path') %>
      </div>
      <div class="flow-arrow"><i class="bi bi-arrow-down-short"></i></div>
      <div class="flow-item">
        <i class="bi bi-book fs-1 d-block mb-2 text-primary"></i>
        <%= t('home.architecture.items.course') %>
      </div>
      <div class="flow-arrow"><i class="bi bi-arrow-down-short"></i></div>
      <div class="flow-item">
        <i class="bi bi-file-text fs-1 d-block mb-2 text-primary"></i>
        <%= t('home.architecture.items.lesson') %>
      </div>
      <div class="flow-arrow"><i class="bi bi-arrow-down-short"></i></div>
      <div class="flow-item">
        <i class="bi bi-question-circle fs-1 d-block mb-2 text-primary"></i>
        <%= t('home.architecture.items.quiz') %>
      </div>
      <div class="flow-arrow"><i class="bi bi-arrow-down-short"></i></div>
      <div class="flow-item">
        <i class="bi bi-award fs-1 d-block mb-2 text-primary"></i>
        <%= t('home.architecture.items.certificate') %>
      </div>
    </div>
  </div>
</section>
