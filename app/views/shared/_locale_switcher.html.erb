<div class="dropdown d-inline-block">
  <button class="btn btn-outline-light btn-sm dropdown-toggle" type="button" id="localeDropdown" data-bs-toggle="dropdown" aria-expanded="false">
    <i class="bi bi-globe2 me-1"></i> <%= t("locales.#{I18n.locale}") %>
  </button>
  <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="localeDropdown">
    <% I18n.available_locales.each do |locale| %>
      <li>
        <%= link_to t("locales.#{locale}"), url_for(locale: locale), class: "dropdown-item #{'active' if locale == I18n.locale}" %>
      </li>
    <% end %>
  </ul>
</div>
